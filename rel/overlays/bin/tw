#!/bin/sh
set -e

SELF=$(readlink "$0" || true)
if [ -z "$SELF" ]; then SELF="$0"; fi
RELEASE_ROOT="$(cd "$(dirname "$SELF")/.." && pwd -P)"

# Ensure epmd is running for distributed Erlang
ensure_epmd() {
  if ! pgrep -x epmd > /dev/null 2>&1; then
    "$RELEASE_ROOT/erts-"*/bin/epmd -daemon 2>/dev/null || epmd -daemon 2>/dev/null || true
  fi
}

# Check if daemon is running by looking for tw_watcher in epmd names
daemon_running() {
  epmd -names 2>/dev/null | grep -q "name tw_watcher"
}

# Encode args as newline-delimited env var for Elixir to parse
export TW_ARGV=""
for arg in "$@"; do
  if [ -z "$TW_ARGV" ]; then
    TW_ARGV="$arg"
  else
    TW_ARGV="$TW_ARGV
$arg"
  fi
done

COMMAND="${1:-}"

if [ "$COMMAND" = "watch" ]; then
  ensure_epmd
  if daemon_running; then
    # Daemon already running, use eval to add directories
    exec "$RELEASE_ROOT/bin/time_watcher" eval 'System.get_env("TW_ARGV", "") |> String.split("\n", trim: true) |> TimeWatcher.CLI.main()'
  else
    # Start daemon in background
    "$RELEASE_ROOT/bin/time_watcher" daemon
  fi
elif [ "$COMMAND" = "stop" ] || [ "$COMMAND" = "list" ] || [ "$COMMAND" = "remove" ]; then
  # Client commands need epmd for distribution
  ensure_epmd
  exec "$RELEASE_ROOT/bin/time_watcher" eval 'System.get_env("TW_ARGV", "") |> String.split("\n", trim: true) |> TimeWatcher.CLI.main()'
else
  # Other commands (report, help) don't need distribution
  exec "$RELEASE_ROOT/bin/time_watcher" eval 'System.get_env("TW_ARGV", "") |> String.split("\n", trim: true) |> TimeWatcher.CLI.main()'
fi
